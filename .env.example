# Discord bot token used by the puppet bot
DISCORD_BOT_TOKEN=your-discord-token

# Avrae bot user id (used to correlate bot responses)
AVRAE_BOT_USER_ID=261302296103747584

# Optional guild/channel defaults
DISCORD_GUILD_ID=
DISCORD_DEFAULT_CHANNEL_ID=
DEFAULT_THREAD_ID=

# Relay tuning
RESPONSE_TIMEOUT_SECONDS=8
MAX_COLLECTED_MESSAGES=6

# MCP server metadata
MCP_SERVER_NAME=avrae-discord-mcp
MCP_SERVER_VERSION=0.1.0
LOG_LEVEL=INFO
